#!/bin/bash
# VM Manager — simple TUI for controlling dev VMs.
# Shows status and provides single-keystroke start/stop/attach actions.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/config.sh"

# Ensure we have incus-admin group access (avoids needing logout/login)
if ! incus info &>/dev/null 2>&1; then
    if getent group incus-admin | grep -qw "$(whoami)"; then
        exec sg incus-admin "$(readlink -f "$0")"
    else
        echo "ERROR: Not in incus-admin group. Run: sudo usermod -aG incus-admin \$(whoami) && newgrp incus-admin"
        exit 1
    fi
fi

# Colors
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

msg=""

get_status() {
    local vm="$1"
    incus list "$vm" --format csv -c s 2>/dev/null || echo "NOT FOUND"
}

color_status() {
    local status="$1"
    case "$status" in
        RUNNING)  echo -e "${GREEN}RUNNING${RESET}" ;;
        STOPPED)  echo -e "${RED}STOPPED${RESET}" ;;
        *)        echo -e "${YELLOW}${status}${RESET}" ;;
    esac
}

draw() {
    clear
    echo -e "${BOLD}  VM Manager${RESET}"
    echo -e "${DIM}  ──────────────────────────────${RESET}"
    echo

    # Status table
    local i=1
    for vm in "${VM_NAMES[@]}"; do
        local status
        status="$(get_status "$vm")"
        local colored
        colored="$(color_status "$status")"
        echo -e "  ${BOLD}${vm}${RESET}  ${colored}"
        ((i++))
    done

    echo
    echo -e "${DIM}  ──────────────────────────────${RESET}"
    echo -e "  ${CYAN}Actions:${RESET}"
    echo

    # Dynamic actions based on VM count
    local n=1
    for vm in "${VM_NAMES[@]}"; do
        local status
        status="$(get_status "$vm")"
        if [[ "$status" == "RUNNING" ]]; then
            echo -e "    ${BOLD}${n}${RESET}  Stop ${vm}"
            echo -e "    ${BOLD}$((n+1))${RESET}  Attach console ${vm}"
        else
            echo -e "    ${BOLD}${n}${RESET}  Start ${vm}"
            echo -e "    ${DIM}$((n+1))  Attach console ${vm} (stopped)${RESET}"
        fi
        ((n+=2))
    done

    echo
    echo -e "    ${BOLD}r${RESET}  Refresh    ${BOLD}q${RESET}  Quit"
    echo

    if [[ -n "$msg" ]]; then
        echo -e "  ${YELLOW}${msg}${RESET}"
        echo
        msg=""
    fi

    echo -n "  > "
}

do_action() {
    local key="$1"
    case "$key" in
        1)
            local status
            status="$(get_status "${VM_NAMES[0]}")"
            if [[ "$status" == "RUNNING" ]]; then
                msg="Stopping ${VM_NAMES[0]}..."
                draw
                "$SCRIPT_DIR/shutdown-vm" "${VM_NAMES[0]}" &>/dev/null &
                wait $!
                msg="${VM_NAMES[0]} stopped."
            else
                msg="Starting ${VM_NAMES[0]}..."
                draw
                "$SCRIPT_DIR/boot-vm" "${VM_NAMES[0]}" &>/dev/null &
                wait $!
                setsid incus console "${VM_NAMES[0]}" --type vga >/dev/null 2>&1 &
                msg="${VM_NAMES[0]} started. Console opened."
            fi
            ;;
        2)
            local status
            status="$(get_status "${VM_NAMES[0]}")"
            if [[ "$status" == "RUNNING" ]]; then
                setsid incus console "${VM_NAMES[0]}" --type vga >/dev/null 2>&1 &
                msg="Console opened for ${VM_NAMES[0]}."
            else
                msg="${VM_NAMES[0]} is not running."
            fi
            ;;
        3)
            if [[ ${#VM_NAMES[@]} -lt 2 ]]; then
                msg="No second VM configured."
                return
            fi
            local status
            status="$(get_status "${VM_NAMES[1]}")"
            if [[ "$status" == "RUNNING" ]]; then
                msg="Stopping ${VM_NAMES[1]}..."
                draw
                "$SCRIPT_DIR/shutdown-vm" "${VM_NAMES[1]}" &>/dev/null &
                wait $!
                msg="${VM_NAMES[1]} stopped."
            else
                msg="Starting ${VM_NAMES[1]}..."
                draw
                "$SCRIPT_DIR/boot-vm" "${VM_NAMES[1]}" &>/dev/null &
                wait $!
                setsid incus console "${VM_NAMES[1]}" --type vga >/dev/null 2>&1 &
                msg="${VM_NAMES[1]} started. Console opened."
            fi
            ;;
        4)
            if [[ ${#VM_NAMES[@]} -lt 2 ]]; then
                msg="No second VM configured."
                return
            fi
            local status
            status="$(get_status "${VM_NAMES[1]}")"
            if [[ "$status" == "RUNNING" ]]; then
                setsid incus console "${VM_NAMES[1]}" --type vga >/dev/null 2>&1 &
                msg="Console opened for ${VM_NAMES[1]}."
            else
                msg="${VM_NAMES[1]} is not running."
            fi
            ;;
        r|R) ;;  # just refresh
        q|Q) exit 0 ;;
        *) ;;
    esac
}

# Main loop
trap 'echo; exit 0' INT
while true; do
    draw
    read -rsn1 key
    [[ -z "$key" ]] && continue
    do_action "$key"
done
