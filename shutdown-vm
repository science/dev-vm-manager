#!/bin/bash
# Gracefully shut down a dev VM.
# Usage: ./shutdown-vm <vm-name>
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/config.sh"

# Ensure we have incus-admin group access (avoids needing logout/login)
if ! incus info &>/dev/null 2>&1; then
    if id -nG | grep -qw incus-admin; then
        exec sg incus-admin "$0 $*"
    else
        echo "ERROR: Not in incus-admin group. Run: sudo usermod -aG incus-admin \$(whoami) && newgrp incus-admin"
        exit 1
    fi
fi

VM_NAME="${1:?Usage: shutdown-vm <vm-name>}"

# Validate VM name
found=false
for name in "${VM_NAMES[@]}"; do
    [[ "$name" == "$VM_NAME" ]] && found=true && break
done
if ! $found; then
    echo "ERROR: Unknown VM name '$VM_NAME'. Known: ${VM_NAMES[*]}"
    exit 1
fi

STATUS="$(incus list "$VM_NAME" --format csv -c s 2>/dev/null || echo "MISSING")"
if [[ "$STATUS" == "RUNNING" ]]; then
    echo "Shutting down $VM_NAME (clean ACPI, 60s timeout)..."
    incus stop "$VM_NAME" --timeout 60
    echo "$VM_NAME stopped."
elif [[ "$STATUS" == "STOPPED" ]]; then
    echo "$VM_NAME is already stopped."
else
    echo "ERROR: VM '$VM_NAME' does not exist."
    exit 1
fi
